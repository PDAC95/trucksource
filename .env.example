# Supabase — get these from your project's API settings once created.
# Public values (sent to the browser): safe to expose.
# Must be the BARE project URL — no trailing path (no /rest/v1/), no leading/trailing spaces.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base origin for email redirect links (e.g. https://yourapp.com or http://localhost:3000)
NEXT_PUBLIC_SITE_URL=

# SERVER-ONLY. Never prefix with NEXT_PUBLIC_. Used only by lib/supabase/admin.ts.
# Exposing this key bypasses all RLS. Keep it out of the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=

# ── Phase 2: Verified Seller / Phone OTP ───────────────────────────────────────
# ALL server-only. Never prefix with NEXT_PUBLIC_ — these must never reach the browser.

# Twilio Verify v2 — phone OTP send/check. Account SID + Auth Token from
# Twilio Console -> Account Info. The Verify Service SID is created in
# Twilio Console -> Verify -> Services (set code length 6, lifetime 600s,
# max attempts 5, channel SMS, Fraud Guard on, Geo Permissions = US + CA only).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Global daily OTP send ceiling (toll-fraud spend cap). Tunable WITHOUT a redeploy.
# Default 200 if unset. Mirror this with a Twilio usage-trigger billing alert.
OTP_SEND_DAILY_CAP=200

# Resend — interim admin alert on spend-cap breach (reuses the existing Resend
# account; no admin console until Phase 10). API key from Resend Dashboard -> API Keys.
RESEND_API_KEY=
# The marketplace admin address to notify on a spend-cap breach.
ABUSE_ALERT_EMAIL=

# ── Phase 5.1: Listing lifecycle near-expiry cron ──────────────────────────────
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_. Generate a random secret and set it
# in Vercel → Project → Settings → Environment Variables (all environments). The
# /api/cron/near-expiry route rejects any request whose Authorization header is not
# `Bearer ${CRON_SECRET}` (Pitfall 6 — the endpoint must not be publicly triggerable).
# Vercel Cron sends this header automatically when CRON_SECRET is set on the project.
CRON_SECRET=
